# Template for local-only environment variables.
#
# Copy to .env.local (gitignored) and fill in your values:
#   cp .env.example .env.local
#   # edit .env.local with your SUNetID etc.
#
# Then source it before running sync/deploy scripts:
#   source .env.local
# or use a shim like `direnv` or `dotenv` to load it automatically.
#
# None of these values should ever be committed.

# Stanford SUNetID — used by sync / submit scripts to talk to Sherlock.
SUNET_ID=abc123

# Sherlock host alias (prefer setting this in ~/.ssh/config and using 'sherlock'
# as the host name; leave this here for scripts that call rsync etc. directly).
SHERLOCK_HOST=sherlock

# Remote project path on Sherlock (usually $HOME/standard_model_2).
# Use literal '$HOME' so it expands on the remote side.
SHERLOCK_PROJECT_DIR='$HOME/standard_model_2'

# Where fits get written on Sherlock. Your SLURM scripts set this too; keep
# them consistent.
SHERLOCK_FITS_DIR='$SCRATCH/standard_model_2/fits'

# Optional: a GitHub personal access token, if you prefer HTTPS pushes over
# SSH for git. (SSH is simpler; only set this if you really want HTTPS.)
# GITHUB_TOKEN=ghp_xxx
